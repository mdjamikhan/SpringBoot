package com.lpu.EmployeeApp.dto;

import jakarta.validation.constraints.Email;
import jakarta.validation.constraints.Max;
import jakarta.validation.constraints.Min;
import jakarta.validation.constraints.NotBlank;
import jakarta.validation.constraints.Pattern;
import jakarta.validation.constraints.Positive;

public class EmployeeDTO {
	
	
	@NotBlank(message="Name should not be null")
 	private String name;
	@Positive(message="Phone No is always positive")
	
//	@Pattern(regexp = "^[6-9]\\d{9}$") //  Pattern is always work with string not with long 
	private long phone;
	
	@Pattern(regexp = "^[A-Za-z0-9+_.-]+@[A-Za-z0-9.-]+$",message="email is not valid")
	@Email(message="email is not valid")
	private String email;
	
	@Min(value=18,message="age should must be greater than 18")
	@Max(value=60,message="age should must be less than 60")

	private int age;
	
	
	
	

	public EmployeeDTO() {
		super();
 	}
 

	public String getName() {
		return name;
	}

	public void setName(String name) {
		this.name = name;
	}

	public long getPhone() {
		return phone;
	}

	public void setPhone(long phone) {
		this.phone = phone;
	}

	public String getEmail() {
		return email;
	}

	public void setEmail(String email) {
		this.email = email;
	}

	public int getAge() {
		return age;
	}

	public void setAge(int age) {
		this.age = age;
	}

}
