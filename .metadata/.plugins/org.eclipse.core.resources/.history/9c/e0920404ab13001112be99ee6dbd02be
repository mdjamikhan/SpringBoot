package com.lpu.demo.controller;

 import java.util.Arrays;
import java.util.List;

import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.RequestParam;
import org.springframework.web.bind.annotation.RestController;

@RestController // from making rest controller we have to make RestController
public class myController {
	@GetMapping("/hii")
	public String takeRequest() {
		
		return "byeee";
		
	}
	@GetMapping("/takeData")
	public String takeData(@RequestParam int  id, @RequestParam String name) {
		
		return "ID="+id+" NAME="+name;	
	}
	
	@GetMapping("/threeData")  //http://localhost:8080/threeData?id=12&name=jami&loc=bihar
	public String allThree(@RequestParam int id,@RequestParam String name, @RequestParam String loc) {
		return "ID= "+id+" NAME="+name+" Loc= "+loc;	
		
	}
	
	
	@GetMapping("/listData")
	public List<String> listData() {
		
		List<String> ls=Arrays.asList("jami","zahir","adil");
		
		return ls;
		
	}
	@GetMapping("/takeData2/{id}")
	public String takeData2(@PathVariable  int id) {
		return "id= "+id;
		
		
	}
	@GetMapping("/takeData3/{id}/{name}")
	public String takeData3(@PathVariable  int id,@PathVariable String name) {
		return "id= "+id+" Name="+name;
		
		
	}
	@GetMapping("/student/{id}/college/{cid}")
	public String getData(@PathVariable int id, @RequestParam int cid) {
	    return "Student ID = " + id+ " College id="+cid ;
	}
	
	

}
